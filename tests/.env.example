# Rancher Authentication
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to git!

TEST_USERNAME=admin
TEST_PASSWORD=<your_password_here>

# Rancher URL
RANCHER_URL=https://<your-rancher-url>.com

# Test Configuration (Optional)
TEST_RETRIES=0

# Qase.io Integration
QASE_MODE=off
QASE_TESTOPS_PROJECT=SS
QASE_TESTOPS_API_TOKEN=<your_api_token_here>
QASE_RUN_ID=
QASE_RUN_TITLE=

# Console Error Output (for demo/screenshots)
# SHOW_CONSOLE_ERRORS=false
